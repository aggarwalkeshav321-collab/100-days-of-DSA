#include <stdio.h>
#include <stdbool.h>

void dfs(int v, int n, int adj[n][n], bool visited[]) {
    visited[v] = true;
    printf("%d ", v);

    for (int i = 0; i < n; i++) {
        if (adj[v][i] && !visited[i]) {
            dfs(i, n, adj, visited);
        }
    }
}

int main() {
    int n;
    scanf("%d", &n);

    int adj[n][n];
    for (int i = 0; i < n; i++) {
        int k;
        scanf("%d", &k);
        for (int j = 0; j < n; j++) adj[i][j] = 0;
        for (int j = 0; j < k; j++) {
            int x;
            scanf("%d", &x);
            adj[i][x] = 1;
        }
    }

    int s;
    scanf("%d", &s);

    bool visited[n];
    for (int i = 0; i < n; i++) visited[i] = false;

    dfs(s, n, adj, visited);

    return 0;
}
