#include <stdio.h>
#include <stdlib.h>

int dfs(int node, int parent, int* visited, int** adj, int* size) {
    visited[node] = 1;

    for(int i = 0; i < size[node]; i++) {
        int neigh = adj[node][i];

        if(!visited[neigh]) {
            if(dfs(neigh, node, visited, adj, size)) return 1;
        } else if(neigh != parent) {
            return 1;
        }
    }

    return 0;
}

int hasCycle(int n, int** adj, int* size) {
    int* visited = (int*)calloc(n, sizeof(int));

    for(int i = 0; i < n; i++) {
        if(!visited[i]) {
            if(dfs(i, -1, visited, adj, size)) return 1;
        }
    }

    return 0;
}

int main() {
    int n;
    scanf("%d", &n);

    int** adj = (int**)malloc(n * sizeof(int*));
    int* size = (int*)calloc(n, sizeof(int));

    for(int i = 0; i < n; i++) {
        int k;
        scanf("%d", &k);
        adj[i] = (int*)malloc(k * sizeof(int));
        size[i] = k;

        for(int j = 0; j < k; j++) {
            scanf("%d", &adj[i][j]);
        }
    }

    if(hasCycle(n, adj, size))
        printf("YES");
    else
        printf("NO");

    return 0;
}
